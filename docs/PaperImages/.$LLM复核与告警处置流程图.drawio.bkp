<mxfile host="app.diagrams.net">
  <diagram id="llm-flow" name="LLM复核与告警处置流程图">
    <mxGraphModel dx="1000" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="840" pageHeight="1200" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== 节点 ===== -->
        <mxCell id="start" value="开始" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="30" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n1" value="接收 YOLO 中置信度结果" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="110" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n2" value="提取告警截图与上下文信息" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="190" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n3" value="调用多模态 LLM 进行语义复核" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="270" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n4" value="返回复核结论与处置建议" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="350" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="d1" value="复核结论是否为真实火灾？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="295" y="428" width="250" height="80" as="geometry"/>
        </mxCell>

        <!-- 左侧分支：真实火灾 -->
        <mxCell id="nL1" value="生成正式告警事件" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="448" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="nL2" value="推送至操作员告警中心" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="528" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="nL3" value="操作员查看告警详情" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="608" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="nL4" value="执行 SOP 处置流程" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="688" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="nL5" value="填写处理备注并提交结果" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="768" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="nL6" value="更新告警状态为已处理" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="65" y="848" width="160" height="40" as="geometry"/>
        </mxCell>

        <!-- 右侧分支：误报 -->
        <mxCell id="nR1" value="记录误报原因" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="615" y="448" width="155" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="nR2" value="标记告警为误报归档" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="615" y="528" width="155" height="40" as="geometry"/>
        </mxCell>

        <!-- 汇合后 -->
        <mxCell id="n5" value="保存复核结果与处理记录" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="968" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n6" value="写入历史告警库" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="1048" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="endnode" value="结束" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="1128" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 连线 ===== -->

        <!-- 主流程 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="start" target="n1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n4" target="d1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 分叉：是 → 左侧 -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d1" target="nL1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6_l" value="是" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e6"><mxGeometry x="-0.5" y="-12" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 分叉：否 → 右侧 -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d1" target="nR1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7_l" value="否" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e7"><mxGeometry x="0.5" y="-12" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 左侧分支内部 -->
        <mxCell id="e8"  style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="nL1" target="nL2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9"  style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="nL2" target="nL3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="nL3" target="nL4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="nL4" target="nL5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="nL5" target="nL6"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 右侧分支内部 -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="nR1" target="nR2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 左侧 → 汇合到 n5 左侧 -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="nL6" target="n5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="265" y="868"/><mxPoint x="265" y="988"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- 右侧 → 汇合到 n5 右侧 -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="nR2" target="n5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="692" y="988"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- 主流程收尾 -->
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n5" target="n6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n6" target="endnode"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
