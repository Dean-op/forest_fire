<mxfile host="app.diagrams.net">
  <diagram id="yolo-flow" name="视频流接入与YOLO巡检流程图">
    <mxGraphModel dx="1000" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1120" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== 节点 ===== -->
        <mxCell id="start" value="开始" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="390" y="30" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_cam" value="接入摄像头视频流" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="110" width="180" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_chk" value="校验设备状态" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="190" width="180" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="d_online" value="设备是否在线？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="335" y="265" width="230" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_err" value="记录设备异常状态" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="635" y="283" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="endnode" value="结束" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="675" y="363" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_cap" value="按设定间隔抓取视频帧" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="385" width="180" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_yolo" value="送入 YOLO 模型检测" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="465" width="180" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="d_fire" value="是否检测到疑似火情目标？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="540" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_next" value="继续下一轮巡检" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="650" y="558" width="150" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_out" value="输出检测类别与置信度" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="665" width="180" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="d_high" value="置信度是否高于告警阈值？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="745" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_gen" value="生成告警记录" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="763" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_save" value="保存告警截图" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="843" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_push" value="推送告警信息" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="923" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="d_low" value="置信度是否低于忽略阈值？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="865" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_lowrisk" value="记为低风险结果" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="650" y="883" width="150" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_llm" value="转入 LLM 复核流程" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="370" y="998" width="160" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 连线（正交直角） ===== -->

        <!-- 开始 → 接入摄像头 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="start" target="n_cam">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 接入摄像头 → 校验设备 -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_cam" target="n_chk">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 校验设备 → 设备是否在线 -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_chk" target="d_online">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 设备是否在线 是 → 按设定间隔抓取 -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="d_online" target="n_cap">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4_l" value="是" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e4"><mxGeometry x="-0.2" y="-10" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 设备是否在线 否 → 记录设备异常 -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="d_online" target="n_err">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5_l" value="否" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e5"><mxGeometry x="-0.5" y="-12" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 记录设备异常 → 结束 -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_err" target="endnode">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 按设定间隔 → 送入YOLO -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_cap" target="n_yolo">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 送入YOLO → 是否检测到火情 -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_yolo" target="d_fire">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 是否检测到火情 是 → 输出检测类别 -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="d_fire" target="n_out">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9_l" value="是" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e9"><mxGeometry x="-0.2" y="-10" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 是否检测到火情 否 → 继续下一轮巡检 -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="d_fire" target="n_next">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10_l" value="否" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e10"><mxGeometry x="-0.5" y="-12" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 继续下一轮巡检 → 回到按设定间隔（右侧上折） -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n_next" target="n_cap">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="725" y="530"/><mxPoint x="820" y="530"/><mxPoint x="820" y="405"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- 输出检测类别 → 置信度是否高于告警阈值 -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_out" target="d_high">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 置信度高于告警阈值 是 → 生成告警记录（向左） -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="d_high" target="n_gen">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e13_l" value="是" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e13"><mxGeometry x="-0.5" y="-12" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 生成告警记录 → 保存告警截图 -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_gen" target="n_save">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 保存告警截图 → 推送告警信息 -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1" source="n_save" target="n_push">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 推送告警信息 → 回到按设定间隔（左侧上折） -->
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n_push" target="n_cap">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="150" y="975"/><mxPoint x="30" y="975"/><mxPoint x="30" y="405"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- 置信度高于告警阈值 否 → 置信度是否低于忽略阈值 -->
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="d_high" target="d_low">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e17_l" value="否" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e17"><mxGeometry x="-0.2" y="-10" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 置信度低于忽略阈值 是 → 记为低风险 -->
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="d_low" target="n_lowrisk">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e18_l" value="是" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e18"><mxGeometry x="-0.5" y="-12" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 置信度低于忽略阈值 否 → 转入LLM复核 -->
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d_low" target="n_llm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e19_l" value="否" style="edgeLabel;html=1;fontSize=12;" vertex="1" connectable="0" parent="e19"><mxGeometry x="-0.2" y="-10" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell>

        <!-- 记为低风险 → 回到按设定间隔（右侧上折） -->
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n_lowrisk" target="n_cap">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="840" y="903"/><mxPoint x="840" y="405"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- 转入LLM → 回到按设定间隔（右侧上折） -->
        <mxCell id="e21" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n_llm" target="n_cap">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="860" y="1018"/><mxPoint x="860" y="405"/></Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
